# ── Postgres ──────────────────────────────────────────────
# Supabase pooler connection string (transaction mode, port 6543)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ── AWS S3 (photo / invoice storage) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=

# ── Optional ──────────────────────────────────────────────
PING_MESSAGE=ping
# Port the API listens on (Render sets this automatically in production)
PORT=3000
# Optional: override the Postgres pool size (defaults to 5 on a long-running server)
# PG_POOL_MAX=5
